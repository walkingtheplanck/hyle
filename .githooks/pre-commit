#!/bin/sh
set -e

echo "=== Pre-commit: same checks as CI ==="

# Auto-format and stage changes before checking
cargo fmt --all
git diff --name-only | xargs -r git add

# Run shared CI checks (clippy, test, doc — fmt already ran above)
sh "$(git rev-parse --show-toplevel)/scripts/ci-check.sh" clippy
sh "$(git rev-parse --show-toplevel)/scripts/ci-check.sh" test
sh "$(git rev-parse --show-toplevel)/scripts/ci-check.sh" doc

echo "=== All checks passed ==="
